{
  "name": "@devobank/core",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest --coverage"
  },
  "peerDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "amqplib": "^0.10.7",
    "bcrypt": "^5.1.1",
    "inversify": "7.0.0-alpha.5",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.27.6",
    "kysely-codegen": "^0.17.0",
    "kysely-ctl": "^0.10.1",
    "kysely-postgres-js": "^2.0.0",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/bcrypt": "^5.0.2"
  },
  "files": ["dist"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/*": {
      "import": "./dist/adapters/*.js",
      "types": "./dist/adapters/*.d.ts"
    },
    "./application/*": {
      "import": "./dist/application/*.js",
      "types": "./dist/application/*.d.ts"
    },
    "./domain/*": {
      "import": "./dist/domain/*.js",
      "types": "./dist/domain/*.d.ts"
    },
    "./ports/*": {
      "import": "./dist/ports/*.js",
      "types": "./dist/ports/*.d.ts"
    }
  }
}
