{
  "name": "devobank",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": " jest --config jest.config.ts",
    "test:watch": " jest --config jest.config.ts --watch",
    "test:cov": " jest --config jest.config.ts --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand  jest --config jest.config.ts",
    "test:int": "TS_NODE_PROJECT=tsconfig.jest.setup.json NODE_OPTIONS=--experimental-vm-modules jest --config jest.config.int.ts",
    "orm:write:migration:create": "mikro-orm migration:create --config src/mikro-orm.write.config.ts",
    "orm:write:migration:up": "mikro-orm migration:up --config src/mikro-orm.write.config.ts",
    "orm:write:migration:down": "mikro-orm migration:down --config src/mikro-orm.write.config.ts",
    "orm:write:migration:list": "mikro-orm migration:list --config src/mikro-orm.write.config.ts",
    "orm:write:migration:pending": "mikro-orm migration:pending --config src/mikro-orm.write.config.ts",
    "orm:write:migration:check": "mikro-orm migration:check --config src/mikro-orm.write.config.ts",
    "orm:write:migration:fresh": "mikro-orm migration:fresh --config src/mikro-orm.write.config.ts",
    "orm:read:migration:create": "mikro-orm migration:create --config src/mikro-orm.read.config.ts",
    "orm:read:migration:up": "mikro-orm migration:up --config src/mikro-orm.read.config.ts",
    "orm:read:migration:down": "mikro-orm migration:down --config src/mikro-orm.read.config.ts",
    "orm:read:migration:list": "mikro-orm migration:list --config src/mikro-orm.read.config.ts",
    "orm:read:migration:pending": "mikro-orm migration:pending --config src/mikro-orm.read.config.ts",
    "orm:read:migration:check": "mikro-orm migration:check --config src/mikro-orm.read.config.ts",
    "orm:read:migration:fresh": "mikro-orm migration:fresh --config src/mikro-orm.read.config.ts"
  },
  "dependencies": {
    "@fastify/static": "^9.1.1",
    "@mikro-orm/cli": "^7.0.9",
    "@mikro-orm/core": "^7.0.9",
    "@mikro-orm/migrations": "^7.0.9",
    "@mikro-orm/nestjs": "^7.0.1",
    "@mikro-orm/postgresql": "^7.0.9",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-fastify": "^11.1.17",
    "@nestjs/swagger": "^11.3.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.4",
    "dotenv": "^17.4.1",
    "ioredis": "^5.10.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.3.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "testcontainers": "^11.13.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "mikro-orm": {
    "useTsNode": true
  }
}
